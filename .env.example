# Solana
# Primary RPC
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# RPC Fallback (free public endpoints)
RPC_URL_FALLBACK_1=https://api.mainnet-beta.solana.com
RPC_URL_FALLBACK_2=https://solana-mainnet.g.alchemy.com/v2/demo

WALLET_PRIVATE_KEY=YOUR_BASE58_OR_UINT8ARRAY_PRIVATE_KEY

# Agent Behavior
CANDLE_TIMEFRAME=15m   # Options: 1m, 3m, 5m, 15m, 30m, 1h, 4h
POLL_INTERVAL_MS=60000
DRY_RUN=true

# RSI Settings
RSI_PERIOD=2
RSI_THRESHOLD=90

# Bollinger Band Settings
BB_PERIOD=20
BB_STD_DEV=2

# GMGN OpenAPI (price feed — required for candle data)
GMGN_API_KEY=your_gmgn_api_key_here

# Telegram Notifications (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exit Transaction Settings
PRIORITY_FEE_MICROLAMPORTS=100000
SLIPPAGE_BPS=100
COMMITMENT=confirmed
